{
  "name": "refactoring-knowledge",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "panda && nuxt build",
    "dev": "panda --watch & nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "format": "oxfmt app server shared *.ts *.json",
    "format:check": "oxfmt app server shared *.ts *.json --check",
    "prepare": "husky",
    "update:issue": "bash .claude/hooks/update-issues.sh"
  },
  "dependencies": {
    "@ark-ui/vue": "^5.36.0",
    "@park-ui/panda-preset": "^0.43.1",
    "@pinia/nuxt": "^0.11.3",
    "@prisma/client": "^7.7.0",
    "better-auth": "^1.6.2",
    "meilisearch": "^0.57.0",
    "nuxt": "^4.4.2",
    "vue": "^3.6.0-beta.9",
    "vue-router": "^5.0.4",
    "zod": "^4.3.6"
  },
  "lint-staged": {
    "*.{ts,vue}": [
      "oxlint",
      "oxfmt"
    ],
    "*.{css,md}": [
      "oxfmt"
    ]
  },
  "devDependencies": {
    "@pandacss/dev": "^1.9.1",
    "@typescript/native-preview": "^7.0.0-dev.20260410.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.59.0",
    "prisma": "^7.7.0"
  },
  "packageManager": "bun@1.3.12"
