    "vue": "^3.5.31",
    "vue-router": "^5.0.4",
    "zod": "^4.3.6"
  },
  "lint-staged": {
    "*.{ts,vue}": ["oxlint", "oxfmt --check"],
    "*.{css,md}": ["oxfmt --check"]
  },
  "devDependencies": {
    "@pandacss/dev": "^1.9.1",
    "@typescript/native-preview": "^7.0.0-dev.20260410.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.59.0",
    "prisma": "^7.7.0"
  }
